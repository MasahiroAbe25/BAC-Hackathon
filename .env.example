# ========================================================
# Ken AIチャット - APIキー設定
# いずれか1つ以上を設定するとAIモードで動作します。
# 未設定の場合はデモ(モック)モードで動作します。
# 複数設定時は上から順に試行し、失敗したら次へ自動フォールバックします。
#
# モデル指定はカンマ区切りで複数記載できます。
# 例: GEMINI_MODEL=gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite
# → 先頭から順に試し、レート上限などで失敗したら次のモデルを使用します。
# ========================================================

# --- OpenRouter (推奨: 多数のモデルを1つのキーで利用可能) ---
# 取得: https://openrouter.ai/
OPENROUTER_API_KEY=
# 使用モデル (省略時: openai/gpt-4o-mini) カンマ区切りで複数指定可
# 例: openai/gpt-4o-mini,openai/gpt-4o,anthropic/claude-3-5-haiku
OPENROUTER_MODEL=

# --- OpenAI (GPT-4o など) ---
# 取得: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# 使用モデル (省略時: gpt-4o-mini) カンマ区切りで複数指定可
# 例: gpt-4o-mini,gpt-4o
OPENAI_MODEL=

# --- Groq (無料枠あり・高速推論) ---
# 取得: https://console.groq.com/keys
GROQ_API_KEY=
# 使用モデル (省略時: llama-3.3-70b-versatile) カンマ区切りで複数指定可
# 例: llama-3.3-70b-versatile,llama-3.1-8b-instant,gemma2-9b-it
GROQ_MODEL=

# --- Mistral AI ---
# 取得: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=
# 使用モデル (省略時: mistral-small-latest) カンマ区切りで複数指定可
# 例: mistral-small-latest,open-mistral-7b
MISTRAL_MODEL=

# --- Google Gemini ---
# 取得: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# 使用モデル (省略時: gemini-2.5-flash) カンマ区切りで複数指定可
# 例: gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite
GEMINI_MODEL=

# --- Anthropic (Claude) ---
# 取得: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# 使用モデル (省略時: claude-haiku-4-5-20251001) カンマ区切りで複数指定可
# 例: claude-haiku-4-5-20251001,claude-sonnet-4-6
ANTHROPIC_MODEL=
